{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "description": "The AI Operating System for Financial Decision Intelligence.",
  "scripts": {
    "dev": "next dev --turbopack -C frontend",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=backend/prisma/schema.prisma",
    "db:push": "prisma db push --schema=backend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=backend/prisma/schema.prisma",
    "db:seed": "tsx backend/prisma/seed.ts",
    "db:studio": "prisma studio --schema=backend/prisma/schema.prisma"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@supabase/supabase-js": "^2.46.0",
    "@supabase/ssr": "^0.5.2",
    "@prisma/client": "^5.22.0",
    "@anthropic-ai/sdk": "^0.32.0",
    "framer-motion": "^11.11.0",
    "recharts": "^2.13.0",
    "lucide-react": "^0.454.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "class-variance-authority": "^0.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^3.4.14",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.1.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
